# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Google Gemini AI (for leave insights feature)
# Get from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Email Notifications (EmailJS)
# 1. Sign up at https://www.emailjs.com
# 2. Add Email Service (Gmail) → copy Service ID
# 3. Create 3 templates with IDs: leave_to_hod, leave_to_admin, leave_to_applicant
# 4. Copy Public Key from Account settings
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
# Optional: override template IDs if you named them differently
# VITE_EMAILJS_TEMPLATE_HOD=leave_to_hod
# VITE_EMAILJS_TEMPLATE_ADMIN=leave_to_admin
# VITE_EMAILJS_TEMPLATE_STAFF=leave_to_applicant

# WhatsApp Notifications (Fonnte)
# 1. Sign up at https://fonnte.com
# 2. Add device → install Fonnte app on sender phone → scan QR
# 3. Copy API token from Dashboard
VITE_FONNTE_TOKEN=your_fonnte_api_token

# System URL (used in notification message links)
VITE_SYSTEM_URL=https://ksbsb-leave-tracker.web.app
